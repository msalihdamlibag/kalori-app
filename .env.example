# --- Anthropic (AI food/exercise/recipe analysis) ---
ANTHROPIC_API_KEY=

# --- Vercel Postgres (history + accounts) ---
POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# --- Vercel Blob (hosted meal photos) ---
BLOB_READ_WRITE_TOKEN=
# Authorizes the daily cron jobs (cleanup + reminders in vercel.json)
CRON_SECRET=

# --- Web Push (daily reminder notifications) ---
# Generate a pair: `npx web-push generate-vapid-keys`
# The public key must also be exposed to the browser (NEXT_PUBLIC_*, same value).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contact URI for the push service (mailto: or https:)
VAPID_SUBJECT=mailto:you@example.com

# --- Auth.js / NextAuth v5 ---
# Random secret: `openssl rand -base64 32`
AUTH_SECRET=
# Deployment URL (e.g. https://app.example.com). Not needed for localhost.
# AUTH_URL=

# Google OAuth (Google Cloud Console → OAuth 2.0 Client ID, Web application).
# Redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Sign in with Apple. AUTH_APPLE_ID is the Services ID. Provide EITHER a
# pre-generated client secret (AUTH_APPLE_SECRET), OR the .p8 key material below
# and the app mints the secret at runtime.
# Redirect URI: <origin>/api/auth/callback/apple
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# Paste the .p8 contents; newlines may be escaped as \n
# APPLE_PRIVATE_KEY=
